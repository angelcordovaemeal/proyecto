        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"DEPOSIT\",\n  \"productId\": \"{{accountId}}\",\n  \"amount\": 200,\n  \"description\": \"Cash deposit\"\n}"
        },
        "url": {
          "raw": "http://localhost:8084/api/v1/movements/deposit",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8084",
          "path": ["api", "v1", "movements", "deposit"]
        }
      }
    },
