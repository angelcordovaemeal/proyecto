      }
    },

    {
      "name": "Get All Credits",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8082/api/v1/credits",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["api", "v1", "credits"]
