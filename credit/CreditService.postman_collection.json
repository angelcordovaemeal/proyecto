        },
        "url": {
          "raw": "http://localhost:8082/api/v1/credits/{{creditId}}/consume",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["api", "v1", "credits", "{{creditId}}", "consume"]
        }
      }
    },

    {
      "name": "Delete Credit",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:8082/api/v1/credits/{{creditId}}",
