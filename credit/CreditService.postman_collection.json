          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["api", "v1", "credits", "{{creditId}}"]
        }
      }
    },

    {
      "name": "List Credits by Customer ID",
      "request": {
        "method": "GET",
        "url": {
