        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"BUSINESS\",\n  \"customerId\": \"biz-100\",\n  \"creditLimit\": 50000,\n  \"usedAmount\": 0,\n  \"interestRate\": 0.15,\n  \"businessName\": \"TechCorp Inc\"\n}"
        },
        "url": {
          "raw": "http://localhost:8082/api/v1/credits",
