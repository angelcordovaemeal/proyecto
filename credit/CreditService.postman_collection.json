  "item": [

    {
      "name": "Create Personal Credit",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"PERSONAL\",\n  \"customerId\": \"cust-100\",\n  \"creditLimit\": 2000,\n  \"usedAmount\": 0,\n  \"interestRate\": 0.12,\n  \"active\": true\n}"
        },
        "url": {
          "raw": "http://localhost:8082/api/v1/credits",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["api", "v1", "credits"]
        }
      }
    },

