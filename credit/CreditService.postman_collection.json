    {
      "name": "Pay Credit (Loan or Credit Card)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 300\n}"
        },
        "url": {
          "raw": "http://localhost:8082/api/v1/credits/{{creditId}}/pay",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["api", "v1", "credits", "{{creditId}}", "pay"]
